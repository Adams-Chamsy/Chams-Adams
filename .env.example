# ==============================================================
# CHAMS ADAMS — Environment Variables
# ==============================================================
# Copier ce fichier en .env.local et remplir les valeurs
# NE JAMAIS commiter .env.local dans Git
# ==============================================================

# --------------------------------------------------------------
# Site
# --------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME="Chams Adams"

# --------------------------------------------------------------
# Sanity CMS
# --------------------------------------------------------------
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01
SANITY_API_TOKEN=

# --------------------------------------------------------------
# Stripe (e-commerce) — étape 7
# --------------------------------------------------------------
# Clés disponibles dans https://dashboard.stripe.com/test/apikeys
# Prod : jamais commiter les clés live — .env.local uniquement
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
# Secret généré par `stripe listen --forward-to localhost:3000/api/webhooks/stripe`
# En prod : copier depuis Dashboard → Developers → Webhooks → votre endpoint
STRIPE_WEBHOOK_SECRET=whsec_...

# --------------------------------------------------------------
# Shopify (alternative à Stripe — à choisir)
# --------------------------------------------------------------
# NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN=
# NEXT_PUBLIC_SHOPIFY_STOREFRONT_ACCESS_TOKEN=

# --------------------------------------------------------------
# Paiements mobiles Afrique (V2)
# --------------------------------------------------------------
# WAVE_API_KEY=
# ORANGE_MONEY_CLIENT_ID=
# ORANGE_MONEY_CLIENT_SECRET=
# MTN_MOMO_API_KEY=

# --------------------------------------------------------------
# Email (newsletter, contact, confirmations) — étape 7
# --------------------------------------------------------------
# Clé API Resend : https://resend.com/api-keys
# Prod : vérifier le domaine chams-adams.com (SPF + DKIM + DMARC)
RESEND_API_KEY=re_...
# Expéditeur affiché dans les mails transactionnels.
# En dev : peut pointer sur onboarding@resend.dev (limité à soi-même).
# En prod : "Chams Adams <contact@chams-adams.com>" après vérification DNS.
CONTACT_EMAIL=contact@chams-adams.com

# --------------------------------------------------------------
# Analytics
# --------------------------------------------------------------
# NEXT_PUBLIC_GA_ID=
# Domaine à renseigner dans plausible.io dashboard (ex. chams-adams.com)
# Le script ne se charge QUE si l'utilisateur a consenti aux cookies
# analytics via le bandeau RGPD.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# --------------------------------------------------------------
# Captcha Cloudflare Turnstile (formulaires sur-mesure + contact)
# --------------------------------------------------------------
# Clés : https://dash.cloudflare.com/?to=/:account/turnstile
# Si NEXT_PUBLIC_TURNSTILE_SITE_KEY est absent, le widget ne s'affiche pas
# et les formulaires passent sans captcha (mode dev).
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# --------------------------------------------------------------
# WhatsApp bouton flottant
# --------------------------------------------------------------
# Numéro international avec l'indicatif (ex. 33612345678, 221771234567)
# Le bouton ne s'affiche pas si ce numéro est vide.
NEXT_PUBLIC_WHATSAPP_NUMBER=
NEXT_PUBLIC_WHATSAPP_MESSAGE="Bonjour, je souhaite échanger avec la Maison Chams Adams."

# --------------------------------------------------------------
# Sentry (monitoring erreurs)
# --------------------------------------------------------------
# DSN client (exposé dans le bundle) + DSN serveur (privé)
# https://sentry.io/settings/projects/:project/keys/
# Si absent : aucun event envoyé (no-op en dev).
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENV=production
# Pour l'upload des source maps au build (optionnel — ne wrappe Sentry qu'avec ça)
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# --------------------------------------------------------------
# Cloudinary / Stockage média (optionnel)
# --------------------------------------------------------------
# NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
